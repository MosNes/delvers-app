{
	"name": "delvers-app",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "npm run build && wrangler dev",
		"deploy": "npm run build && wrangler deploy",
		"reset-db": "npx wrangler d1 execute delvers-db --file=./schemas/reset.sql && npx wrangler d1 execute delvers-db --file=./schemas/schema.sql"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.4",
		"express": "^5.2.1",
		"tailwindcss": "^4.2.4",
		"vue": "^3.5.31",
		"vue-router": "^5.0.4"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.32.3",
		"@vitejs/plugin-vue": "^6.0.5",
		"vite": "^8.0.3",
		"vite-plugin-vue-devtools": "^8.1.1",
		"wrangler": "^4.83.0"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	}
}
